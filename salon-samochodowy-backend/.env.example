# Konfiguracja środowiskowa backendu Salon Samochodowy
# Skopiuj ten plik jako .env i uzupełnij wartości

# Port nasłuchiwania serwera
PORT=3000

# Sekret sesji – zmień na losowy ciąg znaków w produkcji!
# Generuj: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=zmien-ten-sekret-na-losowy-ciag-znakow-w-produkcji

# Dozwolone originy CORS (INC-006) — oddzielone przecinkami
ALLOWED_ORIGINS=http://localhost:4200

# Baza danych (opcjonalne – domyślnie SQLite)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=salon_user
# DB_PASSWORD=zmien_haslo
# DB_NAME=salon_samochodowy
